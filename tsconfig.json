{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",

    "paths": {
      "@app/*": ["./src/app/*"],
      "@auth/*": ["./src/auth/*"],
      "@components/*": ["./src/components/*"],
      "@features/*": ["./src/features/*"],
      "@infra/*": ["./src/infra/*"],
      "@lib/*": ["./src/lib/*"],
      "@push/*": ["./src/push/*"],
      "@realtime/*": ["./src/realtime/*"],
      "@shared/*": ["./src/shared/*"],
      "@storage/*": ["./src/storage/*"],
      "@stores/*": ["./src/stores/*"],
      "@styles/*": ["./src/styles/*"]
    },

    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "src/**/*.ts", "src/**/*.tsx"]
}
