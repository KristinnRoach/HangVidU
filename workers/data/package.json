{
  "name": "hangvidu-data",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker for HangVidU conversation registry persistence, keyed by conversationId.",
  "scripts": {
    "dev": "wrangler dev --env-file .dev.vars.example --port 8788",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "migrate:local": "wrangler d1 migrations apply hangvidu-data --local",
    "migrate:remote": "wrangler d1 migrations apply hangvidu-data --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250508.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.16.0"
  }
}
