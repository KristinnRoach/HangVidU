{
  "name": "hangvidu-data",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker for HangVidU conversation registry persistence, keyed by conversationId.",
  "scripts": {
    "dev": "wrangler dev --env-file .dev.vars.example --port 8788 --persist-to .wrangler/state --local-protocol https --https-cert-path ../../.certs/localhost.pem --https-key-path ../../.certs/localhost-key.pem",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "migrate:local": "wrangler d1 migrations apply hangvidu-data --local --persist-to .wrangler/state",
    "migrate:remote": "wrangler d1 migrations apply hangvidu-data --remote"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.11",
    "@cloudflare/workers-types": "^4.20250508.0",
    "typescript": "^5.6.0",
    "vite": "7.3.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.16.0"
  }
}
