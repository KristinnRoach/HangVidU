{
  "name": "hangvidu-files",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker for authenticated R2 image upload and download.",
  "scripts": {
    "dev": "wrangler dev --port 8789 --env-file .dev.vars --persist-to ../data/.wrangler/state --local-protocol https --https-cert-path ../../.certs/localhost.pem --https-key-path ../../.certs/localhost-key.pem",
    "deploy": "wrangler deploy",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@cloudflare/workers-types": "^4.20250508.0",
    "typescript": "^5.6.0",
    "vite": "7.3.5",
    "vitest": "^4.1.2",
    "wrangler": "^4.16.0"
  }
}
