{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": true,
        ".write": true
      }
    },
    "usersByEmail": {
      "$emailHash": {
        ".read": "auth != null",
        ".write": "auth != null && (newData.child('uid').val() === auth.uid || data.child('uid').val() === auth.uid)"
      }
    },
    "users": {
      "$userId": {
        ".write": "$userId === auth.uid && !newData.exists()",
        "contacts": {
          ".read": "$userId === auth.uid",
          ".write": "$userId === auth.uid"
        },
        "incomingInvites": {
          ".read": "$userId === auth.uid",
          ".write": "$userId === auth.uid && !newData.exists()",
          "$fromUserId": {
            ".write": "auth != null && (($fromUserId === auth.uid && !data.exists()) || ($userId === auth.uid && !newData.exists()))"
          }
        },
        "acceptedInvites": {
          ".read": "$userId === auth.uid",
          ".write": "$userId === auth.uid && !newData.exists()",
          "$acceptedByUserId": {
            ".write": "auth != null && (($acceptedByUserId === auth.uid && !data.exists()) || ($userId === auth.uid && !newData.exists()))"
          }
        },
        "callHistory": {
          ".read": "$userId === auth.uid",
          ".write": "$userId === auth.uid"
        },
        "recentCalls": {
          ".read": "$userId === auth.uid",
          ".write": "$userId === auth.uid"
        },
        "outgoingCall": {
          ".read": "$userId === auth.uid",
          ".write": "$userId === auth.uid"
        },
        "profile": {
          ".read": true,
          ".write": "$userId === auth.uid"
        },
        "presence": {
          ".read": true,
          ".write": "$userId === auth.uid"
        },
        "pushSubscriptions": {
          ".read": "$userId === auth.uid",
          ".write": "$userId === auth.uid"
        },
        "conversations": {
          ".read": "$userId === auth.uid",
          "$conversationId": {
            // LEGACY: allows writing the reverse index for uid1_uid2-format conversations.
            // Once all clients use ensureConversation() (which writes via members authority),
            // this fallback can be replaced with a membership-only check.
            ".write": "auth != null && !data.exists() && newData.val() === true && (($conversationId.contains(auth.uid + '_') || $conversationId.contains('_' + auth.uid)) && ($conversationId.contains($userId + '_') || $conversationId.contains('_' + $userId)))"
          }
        },
        "directConversations": {
          ".read": "$userId === auth.uid",
          "$otherUserId": {
            // Allow a user to write their own directConversations index entry.
            ".write": "$userId === auth.uid && auth != null && !data.exists() && newData.val() != null"
          }
        }
      }
    },
    "notifications": {
      "$userId": {
        ".read": "$userId === auth.uid",
        ".write": "auth != null"
      }
    },
    "conversations": {
      "$conversationId": {
        // Read is allowed if the authenticated user is an explicit member.
        // The legacy uid1_uid2 contains() fallback has been removed — all
        // conversations must have members written via ensureConversation().
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        "members": {
          "$uid": {
            // LEGACY: allows bootstrapping membership for uid1_uid2-format conversations
            // where the ID encodes the participant UIDs. This fallback is kept until all
            // existing conversations have been migrated via migrate-conversation-members.js
            // and the directConversations index is populated. After that, member creation
            // should move to a trusted server path and this rule can be tightened.
            ".write": "auth != null && !data.exists() && newData.val() === true && (($conversationId.contains(auth.uid + '_') || $conversationId.contains('_' + auth.uid)) && ($conversationId.contains($uid + '_') || $conversationId.contains('_' + $uid)))"
          }
        },
        "messages": {
          ".indexOn": ["from"],
          "$messageId": {
            // Write is allowed only if the authenticated user is an explicit member.
            // The legacy uid1_uid2 contains() fallback has been removed.
            ".write": "auth != null && root.child('conversations').child($conversationId).child('members').child(auth.uid).exists()"
          }
        }
      }
    }
  }
}
