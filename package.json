{
  "name": "hangvidu",
  "private": true,
  "version": "0.0.0",
  "description": "P2P video chat with watch-together mode",
  "type": "module",
  "scripts": {
    "build": "pnpm p2p:prod && pnpm ts && VITE_HANGVIDU_API_URL=https://api.hangvidu.com vite build",
    "dev": "pnpm kill:silent && VITE_HANGVIDU_API_URL=https://api.hangvidu.com vite",
    "dev:local": "pnpm kill:silent && VITE_HANGVIDU_API_URL=https://localhost:8788 concurrently -k -n vite,cloudflare \"vite\" \"pnpm dev:cf\"",
    "dev:mobile": "pnpm kill:silent && VITE_HANGVIDU_API_URL=https://api.hangvidu.com concurrently -k -n vite,tunnel \"vite\" \"cloudflared --no-autoupdate tunnel --config /dev/null --url https://localhost:5173 --no-tls-verify run vidu-dev\"",
    "setup:dev-certs": "mkcert -install && mkcert -cert-file .certs/localhost.pem -key-file .certs/localhost-key.pem localhost 127.0.0.1 ::1",
    "dev:cf": "pnpm -C backend/cloudflare run dev",
    "deploy:cf": "pnpm -C backend/cloudflare run deploy",
    "test:cf": "pnpm -C backend/cloudflare run test",
    "lint:cf": "pnpm -C backend/cloudflare run typecheck",
    "p2p:dev": "pnpm link ../kidlib/p2p",
    "p2p:prod": "pnpm unlink @kidlib/p2p && pnpm install",
    "debug:edge": "zsh scripts/debug/launch-pwa-edge.sh",
    "worktree": "scripts/git-worktree.sh",
    "delete:user": "node scripts/delete-user-account.js",
    "kill": "fkill :5173 :4173 :8788 --force; pkill -f 'cloudflared.*vidu-dev' || true",
    "kill:silent": "fkill :5173 :4173 :8788 --force --silent; pkill -f 'cloudflared.*vidu-dev' || true",
    "deploy:fb": "pnpm build && pnpm test:compat && firebase deploy --only hosting",
    "deploy:fb:skip-tests": "pnpm build && firebase deploy --only hosting",
    "deploy:fb:db": "firebase deploy --only database",
    "install:fb:functions": "npm --prefix backend/firebase install",
    "audit:fb:functions": "npm --prefix backend/firebase audit --omit=dev --audit-level=high",
    "install:functions": "pnpm install:fb:functions",
    "deploy:fb:functions": "pnpm install:fb:functions && firebase deploy --only functions",
    "deploy:all": "pnpm build && pnpm install:functions && pnpm test:compat && firebase deploy",
    "deploy:all:skip-tests": "pnpm build && pnpm install:functions && firebase deploy",
    "check:deployment": "if curl -s -o /dev/null -w '%{http_code}' -X POST https://europe-west1-vidu-aae11.cloudfunctions.net/sendCallNotification | grep -E '400|401|405' -q; then echo '✅ Cloud Function is ready'; else echo '❌ Cloud Function not ready'; exit 1; fi",
    "check:prod-routing": "bash scripts/check-production-routing.sh",
    "check:prod-routing:strict": "STRICT_IPV4=1 bash scripts/check-production-routing.sh",
    "d1:view:local": "pnpm -C backend/cloudflare view:local",
    "d1:view:remote": "pnpm -C backend/cloudflare view:remote",
    "migrate:local": "pnpm -C backend/cloudflare run migrate:local",
    "migrate:clean:local": "node -e \"require('node:fs').rmSync('backend/cloudflare/.wrangler/state/v3/d1',{recursive:true,force:true})\" && pnpm migrate:local",
    "migrate:rtdb-files:r2:dry": "node scripts/migrate-rtdb-files-to-r2.js",
    "migrate:rtdb-files:r2": "node scripts/migrate-rtdb-files-to-r2.js --write",
    "migrate:rtdb-files:r2:rewrite-legacy:dry": "node scripts/migrate-rtdb-files-to-r2.js --rewrite-legacy-keys",
    "migrate:rtdb-files:r2:rewrite-legacy": "node scripts/migrate-rtdb-files-to-r2.js --rewrite-legacy-keys --write",
    "migrate:rtdb-files:r2:verify-legacy-copies": "node scripts/migrate-rtdb-files-to-r2.js --verify-legacy-copies",
    "play:rtdb": "open ./playgrounds/rtdb-schema.html",
    "play:rtdb-live": "fkill :8080 :8081 --silent; node --env-file=.env.development ./playgrounds/rtdb-proxy.js & python3 -m http.server 8080 --directory . & sleep 0.5 && open http://localhost:8080/playgrounds/rtdb-live.html && wait",
    "play:boundaries:scan": "node ./playgrounds/build-import-graph.mjs",
    "play:boundaries": "pnpm play:boundaries:scan && fkill :8082 --silent; python3 -m http.server 8082 --directory . & sleep 0.5 && open http://localhost:8082/playgrounds/boundary-rules.html && wait",
    "play:media": "vite --open ./src/shared/media-next/media-lab.html",
    "preview": "pnpm kill:silent && pnpm build && concurrently -k -n preview,tunnel \"vite preview\" \"cloudflared tunnel run vidu-dev\"",
    "preview:local": "pnpm build && vite preview",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" && pnpm lint:cf && pnpm lint:boundaries",
    "lint:boundaries": "eslint --config eslint.boundaries.config.js \"src/**/*.{js,jsx,ts,tsx}\"",
    "ts": "tsc --noEmit",
    "test": "vitest --run",
    "test:node": "vitest --run --project node",
    "test:browser": "vitest --run --project browser",
    "test:all": "pnpm test:compat && pnpm test:e2e",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage",
    "test:compat": "vitest --run --project node && COMPAT=true vitest --run --project browser",
    "test:file-transfer": "node tests/integration/run-file-transfer.js",
    "test:file-transfer:full": "node tests/integration/run-file-transfer.js --sizes 100,250,500,750,900,1024",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "check-deps": "pnpm why glob pnpm why node-domexception pnpm why source-map pnpm why sourcemap-codec"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kristinnroach/hangvidu"
  },
  "keywords": [
    "webrtc",
    "video-chat",
    "peer-to-peer",
    "watch-together",
    "youtube"
  ],
  "author": "Kristinn Roach",
  "license": "UNLICENSED",
  "engines": {
    "node": "^22.19.0 || >=24.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@solidjs/testing-library": "^0.8.10",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "baseline-browser-mapping": "^2.10.40",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "fallow": "^2.103.0",
    "fast-check": "^4.8.0",
    "firebase-admin": "^14.1.0",
    "fkill-cli": "~9.0.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "solid-devtools": "^0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.3.5",
    "vite-plugin-mkcert": "^2.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-solid": "^2.11.12",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "workbox-build": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "dependencies": {
    "@kidlib/create-component": "^0.1.5",
    "@kidlib/p2p": "^0.2.3",
    "@mediabunny/ac3": "^1.49.0",
    "@sentry/browser": "^10.62.0",
    "firebase": "^12.15.0",
    "lucide-solid": "^1.22.0",
    "mediabunny": "^1.49.0",
    "solid-js": "^1.9.13",
    "workbox-window": "^7.4.1",
    "zod": "^4.4.3"
  }
}
