{
  "name": "hangvidu",
  "private": true,
  "version": "0.0.0",
  "description": "P2P video chat with watch-together mode",
  "type": "module",
  "scripts": {
    "dev": "pnpm kill:silent && concurrently \"vite\" \"pnpm ngrok\" \"sh scripts/show-ngrok-url.sh\"",
    "dev:media": "vite --open /media-lab.html",
    "dev:components": "VITE_ENABLE_PWA=0 vite --open components-lab.html",
    "debug:edge": "zsh scripts/debug/launch-pwa-edge.sh",
    "delete:user": "node scripts/delete-user-account.js",
    "kill": "fkill :5173 :4040 --force",
    "kill:silent": "fkill :5173 :4040 --force --silent",
    "ngrok": "ngrok http https://localhost:5173 ${NGROK_DOMAIN:+--domain=$NGROK_DOMAIN}",
    "build": "vite build",
    "deploy:fb": "pnpm build && pnpm test:compat && firebase deploy --only hosting",
    "deploy:fb:skip-tests": "pnpm build && firebase deploy --only hosting",
    "deploy:fb:db": "firebase deploy --only database",
    "deploy:fb:functions": "firebase deploy --only functions",
    "deploy:all": "pnpm build && pnpm test:compat && firebase deploy",
    "deploy:all:skip-tests": "pnpm build  && firebase deploy",
    "check:deployment": "if curl -s -o /dev/null -w '%{http_code}' -X POST https://europe-west1-vidu-aae11.cloudfunctions.net/sendCallNotification | grep -E '400|401|405' -q; then echo '✅ Cloud Function is ready'; else echo '❌ Cloud Function not ready'; exit 1; fi",
    "preview": "vite preview",
    "preview:https": "PREVIEW_HTTPS=1 vite preview",
    "preview:pwa": "pnpm build && pnpm preview:https",
    "lint": "pnpm lint:boundaries && eslint \"src/**/*.js\"",
    "lint:boundaries": "eslint --config eslint.boundaries.config.js \"src/**/*.js\"",
    "lint:b:all": "BOUNDARIES_ENFORCE_ALL=1 pnpm lint:boundaries",
    "lint:b:auth": "BOUNDARIES_AUTH=1 pnpm lint:boundaries",
    "lint:b:feature": "sh -c 'test -n \"$1\" || { echo \"Usage: pnpm lint:b:feature <name>\"; exit 1; }; BOUNDARIES_ENFORCED_FEATURES=\"$1\" pnpm lint:boundaries' --",
    "test": "vitest --run",
    "test:node": "vitest --run --project node",
    "test:browser": "vitest --run --project browser",
    "test:all": "pnpm test:compat && pnpm test:e2e",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage",
    "test:compat": "vitest --run --project node && COMPAT=true vitest --run --project browser",
    "test:file-transfer": "node tests/integration/run-file-transfer.js",
    "test:file-transfer:full": "node tests/integration/run-file-transfer.js --sizes 100,250,500,750,900,1024",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kristinnroach/hangvidu"
  },
  "keywords": [
    "webrtc",
    "video-chat",
    "peer-to-peer",
    "watch-together",
    "youtube"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "baseline-browser-mapping": "^2.10.18",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "fast-check": "^4.6.0",
    "firebase-admin": "^13.7.0",
    "fkill-cli": "~9.0.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "vite": "^7.3.1",
    "vite-plugin-mkcert": "^1.17.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2",
    "workbox-build": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "dependencies": {
    "@sentry/browser": "^10.47.0",
    "dexie": "^4.4.2",
    "firebase": "^12.11.0",
    "lucide": "^1.7.0",
    "mediabunny": "^1.40.1",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "ajv@>=8": "8.18.0",
      "eslint>ajv": "6.12.6",
      "fast-xml-parser": "5.5.7",
      "lodash": "4.18.1",
      "minimatch@>=5 <5.1.7": "5.1.9",
      "minimatch@>=9 <9.0.6": "9.0.9",
      "minimatch@>=10 <10.2.1": "10.2.5",
      "node-forge": "1.4.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4 <4.0.4": "4.0.4",
      "serialize-javascript": "7.0.5"
    }
  }
}
