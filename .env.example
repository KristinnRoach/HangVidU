# Example environment file for HangVidU
# Copy this file to .env.development and/or .env.production and fill in your actual values.

# Hosted production URL of the app 
VITE_APP_URL=your_production_url_here

# Google
VITE_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Firebase
VITE_FIREBASE_API_KEY=your_api_key_here
# AUTH_DOMAIN differs by environment for popup auth to work correctly:
# - Development (.env.development): your_project.firebaseapp.com
# - Production (.env.production): your_project.web.app (must match hosting URL origin)
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_APP_ID=your_app_id_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.region.firebasedatabase.app
# Optional
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# reCAPTCHA Enterprise Site Key for Firebase App Check (score-based, not checkbox)
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=your_recaptcha_enterprise_site_key_here

# YouTube Data API v3 (for YT search)
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# PWA
# Set to 0 to disable PWA registration/update handling.
VITE_ENABLE_PWA=1

# Realtime signaling (Cloudflare Durable Object worker)
# ws://localhost:8787 for `wrangler dev`; wss://<your-worker-domain> in prod.
VITE_SIGNALING_URL=ws://localhost:8787
# 'do' = Durable Object (Cloudflare), 'rtdb' = legacy Firebase RTDB fallback.
VITE_SIGNALING_BACKEND=do

# R2-backed files Worker
# http://localhost:8789 for `pnpm dev:files`; https://<your-files-worker> in prod.
VITE_FILES_URL=http://localhost:8789

# Data worker (D1 conversation registry)
VITE_DATA_URL=http://localhost:8788
# 'd1' = Cloudflare data worker, 'rtdb' = legacy Firebase RTDB fallback.
VITE_MESSAGE_BACKEND=d1
