# Copy to .env.r2.local. Do not commit the local file.

# Cloudflare R2 account and S3-compatible credentials.
# Create the token from R2 > Manage R2 API tokens with object read/write access
# for the target bucket.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=hangvidu-message-files

# Public read base used by the minimal first slice.
# Use an R2 custom domain or temporary r2.dev public bucket URL.
R2_PUBLIC_BASE_URL=https://files.example.com

# Firebase Admin credentials for reading/writing RTDB.
# If unset, the migration script falls back to functions/service-account-key.json
# and then Application Default Credentials.
GOOGLE_APPLICATION_CREDENTIALS=functions/service-account-key.json
FIREBASE_DATABASE_URL=https://your_project-default-rtdb.region.firebasedatabase.app
