{
  "name": "hangvidu-cloudflare",
  "version": "0.0.0",
  "private": true,
  "description": "Consolidated Cloudflare Worker for HangVidU data, files, and realtime coordination.",
  "type": "module",
  "scripts": {
    "predev": "pnpm migrate:local",
    "dev": "wrangler dev --env-file .dev.vars.example --var APP_ENV:development --port 8788 --persist-to .wrangler/state --local-protocol https --https-cert-path ../../.certs/localhost.pem --https-key-path ../../.certs/localhost-key.pem",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vp test --run",
    "migrate:local": "wrangler d1 migrations apply hangvidu-data --local --persist-to .wrangler/state",
    "migrate:remote": "wrangler d1 migrations apply hangvidu-data --remote",
    "view:local": "find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -maxdepth 1 -type f -name '*.sqlite' ! -name 'metadata.sqlite' -exec open {} \\;",
    "view:remote": "open https://dash.cloudflare.com/a9d78083083154be83f36552c213a269/workers/d1/databases/cfac7c1c-cb3c-430d-b33d-6fd12aac48d0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@cloudflare/workers-types": "^4.20260630.1",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.102.0"
  }
}
