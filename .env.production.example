# Production environment template for HangVidU
# Copy this file to .env.production locally for testing (DO NOT commit credentials).

# Hosted production URL of the app 
VITE_APP_URL=your_production_url_here

# Google
VITE_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Firebase
# Production AUTH_DOMAIN must match hosting origin (e.g. your_project.web.app)
VITE_FIREBASE_AUTH_DOMAIN=your_project.web.app

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_APP_ID=your_app_id_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.region.firebasedatabase.app
# Optional
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Web Push
VITE_PUSH_VAPID_KEY=your_web_push_public_vapid_key_here
# reCAPTCHA Enterprise Site Key for Firebase App Check
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=your_recaptcha_enterprise_site_key_here

# YouTube Data API v3 (for YT search)
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# PWA
VITE_ENABLE_PWA=1

# Realtime signaling (Cloudflare Durable Object worker)
VITE_SIGNALING_URL=wss://hangvidu-signaling.<subdomain>.workers.dev
VITE_SIGNALING_BACKEND=do

# R2-backed files Worker
VITE_FILES_URL=https://hangvidu-files.<subdomain>.workers.dev

# Data worker (D1 conversation registry)
VITE_DATA_URL=https://hangvidu-data.<subdomain>.workers.dev

# Security
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
